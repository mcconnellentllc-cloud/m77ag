generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS — Kyle and Brandi only
// ============================================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")

  emailAccounts EmailAccount[]
  emailRules    EmailRule[]
  blockedSenders BlockedSender[]
  bills         Bill[]
  payments      Payment[]
  documents     Document[]
  activityLogs  ActivityLog[]

  @@map("users")
}

// ============================================================
// BUSINESS ENTITIES — The 10 entities
// ============================================================
model Entity {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  color       String
  icon        String
  description String?

  emailAccounts EmailAccount[]
  emails        Email[]
  emailRules    EmailRule[]
  bills         Bill[]
  expenses      Expense[]
  revenue       Revenue[]
  documents     Document[]
  activityLogs  ActivityLog[]

  @@map("entities")
}

// ============================================================
// EMAIL ACCOUNTS — The 11 connected accounts
// ============================================================
model EmailAccount {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  provider        String    // gmail | outlook
  emailAddress    String    @unique @map("email_address")
  displayName     String    @map("display_name")
  accessToken     String?   @map("access_token")
  refreshToken    String?   @map("refresh_token")
  tokenExpiresAt  DateTime? @map("token_expires_at")
  lastSyncAt      DateTime? @map("last_sync_at")
  syncEnabled     Boolean   @default(true) @map("sync_enabled")
  entityId        String?   @map("entity_id")
  color           String?
  isSharedMailbox Boolean   @default(false) @map("is_shared_mailbox")
  primaryAccountId String?  @map("primary_account_id")

  user    User     @relation(fields: [userId], references: [id])
  entity  Entity?  @relation(fields: [entityId], references: [id])
  emails  Email[]

  @@map("email_accounts")
}

// ============================================================
// EMAILS — Metadata only, NOT full bodies
// ============================================================
model Email {
  id                String    @id @default(cuid())
  accountId         String    @map("account_id")
  providerMessageId String    @map("provider_message_id")
  threadId          String?   @map("thread_id")
  subject           String?
  senderEmail       String    @map("sender_email")
  senderName        String?   @map("sender_name")
  recipients        Json?     // jsonb array of recipients
  snippet           String?   // first 200 chars
  bodyPreview       String?   @map("body_preview") // first 1000 chars
  entityId          String?   @map("entity_id")
  priority          String    @default("medium") // critical, high, medium, low, none
  isBill            Boolean   @default(false) @map("is_bill")
  needsResponse     Boolean   @default(false) @map("needs_response")
  aiSummary         String?   @map("ai_summary")
  isRead            Boolean   @default(false) @map("is_read")
  isStarred         Boolean   @default(false) @map("is_starred")
  isArchived        Boolean   @default(false) @map("is_archived")
  hasAttachments    Boolean   @default(false) @map("has_attachments")
  snoozedUntil      DateTime? @map("snoozed_until")
  assignedTo        String?   @map("assigned_to") // user id
  receivedAt        DateTime  @map("received_at")
  processedAt       DateTime? @map("processed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  account EmailAccount @relation(fields: [accountId], references: [id])
  entity  Entity?      @relation(fields: [entityId], references: [id])
  bills   Bill[]

  @@unique([accountId, providerMessageId])
  @@index([entityId])
  @@index([priority])
  @@index([receivedAt])
  @@index([isBill])
  @@index([needsResponse])
  @@index([isArchived])
  @@map("emails")
}

// ============================================================
// EMAIL RULES — User-defined sorting rules
// ============================================================
model EmailRule {
  id             String  @id @default(cuid())
  userId         String  @map("user_id")
  conditionType  String  @map("condition_type") // sender, domain, subject, keyword
  conditionValue String  @map("condition_value")
  assignEntityId String? @map("assign_entity_id")
  assignPriority String? @map("assign_priority")
  isActive       Boolean @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  entity Entity? @relation(fields: [assignEntityId], references: [id])

  @@map("email_rules")
}

// ============================================================
// BLOCKED SENDERS — Permanently blocked
// ============================================================
model BlockedSender {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  emailOrDomain String   @map("email_or_domain")
  blockedAt     DateTime @default(now()) @map("blocked_at")

  user User @relation(fields: [userId], references: [id])

  @@map("blocked_senders")
}

// ============================================================
// BILLS — All bills from all sources
// ============================================================
model Bill {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  emailId        String?   @map("email_id")
  entityId       String    @map("entity_id")
  vendor         String
  invoiceNumber  String?   @map("invoice_number")
  amount         Decimal   @db.Decimal(12, 2)
  dueDate        DateTime? @map("due_date")
  paymentTerms   String?   @map("payment_terms")
  status         String    @default("pending") // pending, paid, overdue, disputed
  isRecurring    Boolean   @default(false) @map("is_recurring")
  lineItems      Json?     @map("line_items") // jsonb array
  scannedImageUrl String?  @map("scanned_image_url")
  source         String    @default("manual") // email, scan, manual
  expenseCategory String?  @map("expense_category")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  email    Email?    @relation(fields: [emailId], references: [id])
  entity   Entity    @relation(fields: [entityId], references: [id])
  payments Payment[]
  expenses Expense[]

  @@index([entityId])
  @@index([status])
  @@index([dueDate])
  @@map("bills")
}

// ============================================================
// PAYMENTS — Payment records when bills are paid
// ============================================================
model Payment {
  id           String   @id @default(cuid())
  billId       String   @map("bill_id")
  paidByUserId String   @map("paid_by_user_id")
  paymentDate  DateTime @map("payment_date")
  checkNumber  String?  @map("check_number")
  bankAccount  String?  @map("bank_account")
  amountPaid   Decimal  @db.Decimal(12, 2) @map("amount_paid")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  bill    Bill     @relation(fields: [billId], references: [id])
  paidBy  User     @relation(fields: [paidByUserId], references: [id])
  expenses Expense[]

  @@map("payments")
}

// ============================================================
// EXPENSES — Auto-created from payments + manual entry
// ============================================================
model Expense {
  id           String   @id @default(cuid())
  entityId     String   @map("entity_id")
  billId       String?  @map("bill_id")
  paymentId    String?  @map("payment_id")
  date         DateTime
  vendor       String
  amount       Decimal  @db.Decimal(12, 2)
  category     String
  subcategory  String?
  checkNumber  String?  @map("check_number")
  bankAccount  String?  @map("bank_account")
  notes        String?
  source       String   @default("manual") // bill_payment, manual
  receiptUrl   String?  @map("receipt_url")
  createdAt    DateTime @default(now()) @map("created_at")

  entity  Entity   @relation(fields: [entityId], references: [id])
  bill    Bill?    @relation(fields: [billId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([entityId])
  @@index([category])
  @@index([date])
  @@map("expenses")
}

// ============================================================
// REVENUE — Manual revenue entries (for now)
// ============================================================
model Revenue {
  id                String   @id @default(cuid())
  entityId          String   @map("entity_id")
  date              DateTime
  sourceDescription String   @map("source_description")
  amount            Decimal  @db.Decimal(12, 2)
  category          String?
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([date])
  @@map("revenue")
}

// ============================================================
// DOCUMENTS — Scanned documents and uploads
// ============================================================
model Document {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  entityId        String?  @map("entity_id")
  documentType    String   @map("document_type") // bill, receipt, document, other
  fileUrl         String   @map("file_url")
  ocrText         String?  @map("ocr_text")
  aiExtractedData Json?    @map("ai_extracted_data")
  createdAt       DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  entity Entity? @relation(fields: [entityId], references: [id])

  @@map("documents")
}

// ============================================================
// ACTIVITY LOG — Who did what when
// ============================================================
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  actionType  String   @map("action_type")
  description String
  entityId    String?  @map("entity_id")
  relatedId   String?  @map("related_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  entity Entity? @relation(fields: [entityId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================
// SENDER CACHE — Cached sender categorizations to reduce AI costs
// ============================================================
model SenderCache {
  id        String   @id @default(cuid())
  email     String   @unique
  entityId  String?  @map("entity_id")
  priority  String?
  isBill    Boolean  @default(false) @map("is_bill")
  hitCount  Int      @default(1) @map("hit_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sender_cache")
}
